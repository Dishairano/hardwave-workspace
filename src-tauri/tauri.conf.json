  "version": "0.2.5",
  "identifier": "com.hardwavestudios.workspace",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3008",
    "frontendDist": "https://workspace.hardwavestudios.com"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hardwave Workspace",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
